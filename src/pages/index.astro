---
import Base from '../layouts/Base.astro';
import GridBackground from '../components/GridBackground.astro';
import SignalTrace from '../components/SignalTrace.astro';
import GlobalNBody from '../components/GlobalNBody.astro'; 

const experience = [
  // { date: 'Fall 2026 - present',   role: 'Member of Technical Staff',  company: 'xAI', detail: 'LLM research.' },
  // { date: 'Summer 2026',   role: 'Flight Software Intern',  company: 'Hermeus', detail: 'Hypersonics work. Flight software for Quarterhorse.' },
  // { date: 'Fall 2026 - present',   role: 'Firmware Engineer',  company: 'Anduril', detail: 'Autonomous robotics.' },
  // { date: 'Fall 2026 - present',   role: 'Software Engineer',  company: 'Google', detail: 'LLM research.' },
  { date: 'Summer 2025',   role: 'Software / Controls Intern',  company: 'MIT', detail: 'Advanced defense research at Lincoln Labs. Controls and embedded systems.' },
  { date: 'Spring 2025', role: 'Software / Avionics Intern',  company: 'SpaceX',                 detail: 'Flight software and avionics systems for Falcon.' },
  { date: 'Summer 2024',  role: 'Software Engineering Intern', company: 'Kitware',                detail: 'Research for the AFRL into long-range threat identification.' },
];
const skills = [
  {
    category: "Embedded & Hardware",
    items: [
      "C/C++",
      "STM32",
      "FreeRTOS",
      "PCB Design",
      "KiCad / Altium",
      "Verilog / VHDL",
      "I2C / SPI / UART",
      "Hardware Debugging",
      "Linux",
      "Bash",
    ]
  },
  {
    category: "Robotics & Controls",
    items: [
      "ROS / ROS2",
      "ArduPilot",
      "PX4",
      "MAVLink",
      "Gazebo",
      "Control Systems",
      "State Estimation",
      "OpenCV",
    ]
  },
  {
    category: "Aerospace",
    items: [
      "Orbital Mechanics",
      "Flight Dynamics",
      "Astrodynamics",
      "GNC",
      "MATLAB / Simulink",
    ]
  },
  {
    category: "Software",
    items: [
      "Python",
      "TypeScript",
      "React / Next.js",
      "Node.js",
      "REST APIs",
      "SQL",
      "Docker",
      "AWS",
      "Git",
    ]
  },
];
---

<Base>
  <div style="position:relative;background:var(--cream); padding-bottom: 60px;">
    
    <GlobalNBody transition:persist/>
    <GridBackground />

    <section style="padding: 100px 40px; position:relative; z-index:1;">
      <SignalTrace />
      
      <div style="max-width: 800px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; text-align: center;">
        
        <p style="font-family:var(--font-mono);font-size:11px;color:var(--copper);letter-spacing:0.15em;text-transform:uppercase;margin-bottom:14px; white-space:nowrap;">
          CE + Aerospace // UMich
        </p>
        
        <h1 class="serif" style="font-size:clamp(48px,10vw,80px);color:var(--ink);font-weight:400;line-height:0.95;letter-spacing:-2px;margin-bottom:24px;">
          Hi, I'm Teja.
        </h1>
        
        <p style="font-family:var(--font-mono); font-size:15px; color:var(--muted); line-height:1.8; max-width: 600px; margin-bottom:36px;">
          Welcome to my notebook. 
        </p>
        
        <div style="display:flex; gap:20px; margin-bottom:36px; align-items:center;">
          <a href="https://github.com/tskoduru" target="_blank" class="social-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="#181717"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          </a>
          
          <a href="https://linkedin.com/in/tskoduru" target="_blank" class="social-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="#0A66C2"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451c.981 0 1.778-.773 1.778-1.729V1.729C24 .774 23.206 0 22.225 0z"/></svg>
          </a>
        
          <a href="https://www.youtube.com/channel/UCPVpYLoGEPTj0m5vAhHjr_w" target="_blank" class="social-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="#FF0000"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>
        
        <style>
          .social-icon {
            transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275), opacity 0.2s ease;
            opacity: 0.8;
          }
          .social-icon:hover {
            transform: scale(1.2);
            opacity: 1;
          }
        </style>

        <div style="display:flex; gap:16px; flex-wrap:wrap; justify-content:center;">
          <a href="/projects" class="btn-primary">view projects</a>
          <a href="/TKoduru_Resume.pdf" target="_blank" class="btn-ghost">download resume</a>
        </div>
        
      </div>
      
    </section>

    <section style="padding: 0 40px; margin-top: 24px; position: relative; z-index: 1;">
      
      <div style="max-width: 1100px; margin: 0 auto;">
        
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 48px; align-items: start;">
          
          <div>
            <div style="display: flex; align-items: baseline; gap: 14px; margin-bottom: 24px;">
              <span class="section-num">01 //</span>
              <span class="serif" style="font-size: 20px; color: var(--ink); font-weight: 400; font-style: italic;">experience</span>
              <hr class="section-rule" />
            </div>

            <div class="exp-timeline">
              {experience.map(e => (
                <div class="exp-node">
                  <div class="exp-card">
                    <div style="display: flex; justify-content: space-between; align-items: baseline;">
                      <div style="font-size: 15px; color: var(--ink); font-weight: 500;">{e.company}</div>
                      <div style="font-family: var(--font-mono); font-size: 10px; color: var(--muted-light); letter-spacing: 0.05em;">{e.date}</div>
                    </div>
                    
                    <div class="exp-detail-wrapper">
                      <div class="exp-detail-inner">
                        <div style="font-family: var(--font-mono); font-size: 12px; color: var(--copper); margin-top: 8px; margin-bottom: 4px;">
                          ↳ {e.role}
                        </div>
                        <div style="font-family: var(--font-mono); font-size: 12px; color: var(--muted); line-height: 1.5;">
                          {e.detail}
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div>
            <div style="display: flex; align-items: baseline; gap: 14px; margin-bottom: 24px;">
              <span class="section-num">02 //</span>
              <span class="serif" style="font-size: 20px; color: var(--ink); font-weight: 400; font-style: italic;">skills & tools</span>
              <hr class="section-rule" />
            </div>
          
            <div class="skills-card">
              {skills.map((skill, i) => (
                <div class="skills-group" data-open={"false"}>
                  <button class="skills-group-header">
                    <span>{skill.category}</span>
                    <span class="skills-chevron">↓</span>
                  </button>
                  <div class="skills-group-body">
                    <div class="skills-group-inner">
                      <div style="display: flex; flex-wrap: wrap; gap: 8px; padding: 12px 0 4px;">
                        {skill.items.map(item => (
                          <span class="copper-tag interactive-tag">{item}</span>
                        ))}
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

        </div> </div> </section>

  </div>
</Base>

<style>

  .btn-primary {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--cream);
    background: var(--ink);
    padding: 11px 24px; 
    border-radius: 2px;
    text-decoration: none;
    border: 1px solid var(--ink);
    transition: all 0.2s ease;
    white-space: nowrap;
  }
  .btn-primary:hover {
    background: var(--cream);
    color: var(--ink);
  }

  .btn-ghost {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
    background: transparent;
    border: 1px solid rgba(58,46,26,0.4);
    padding: 11px 24px;
    border-radius: 2px;
    text-decoration: none;
    transition: all 0.2s ease;
    white-space: nowrap;
  }
  .btn-ghost:hover {
    background: var(--ink);
    color: var(--cream);
    border-color: var(--ink);
  }

  .skills-card {
    display: flex;
    flex-direction: column;
    gap: 24px;
    background-color: var(--cream-card);
    background-image: radial-gradient(var(--grid-line) 1px, transparent 1px);
    background-size: 16px 16px;
    border: 1px dashed var(--sketch-stroke);
    padding: 24px;
    border-radius: 2px;
  }

  .interactive-tag {
    cursor: default;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .interactive-tag:hover {
    background: var(--copper);
    color: var(--cream);
    transform: translateY(-2px);
    box-shadow: 0 4px 8px var(--copper-dim);
    border-color: var(--copper);
  }

  .exp-timeline {
    position: relative;
    padding-left: 32px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  
  .exp-timeline::before {
    content: '';
    position: absolute;
    top: 16px;
    bottom: 24px;
    left: 0;
    width: 1px;
    background: var(--copper);
    opacity: 0.3;
  }

  .exp-node {
    position: relative;
    cursor: crosshair; 
  }

  .exp-node::before {
    content: '';
    position: absolute;
    top: 22px;
    left: -32px;
    width: 16px;
    height: 1px;
    background: var(--copper);
    opacity: 0.3;
    transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
  }

  .exp-node::after {
    content: '';
    position: absolute;
    top: 19px;
    left: -16px;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    border: 1px solid var(--copper);
    background: var(--cream);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .exp-card {
    padding: 14px 16px;
    border: 1px dashed transparent;
    border-radius: 2px;
    background: transparent;
    transition: all 0.3s ease;
  }

  .exp-node:hover::before {
    width: 22px; 
    opacity: 0.8;
  }

  .exp-node:hover::after {
    left: -10px; 
    background: var(--copper); 
    box-shadow: 0 0 0 3px var(--copper-dim); 
  }

  .exp-node:hover .exp-card {
    background: var(--cream-card);
    border-color: var(--sketch-stroke);
  }

  .exp-detail-wrapper {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .exp-detail-inner {
    overflow: hidden;
  }
  .exp-node:hover .exp-detail-wrapper {
    grid-template-rows: 1fr;
  }

  .skills-group-header {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: none;
  border: none;
  border-bottom: 1px solid var(--rule);
  padding: 10px 0;
  cursor: pointer;
  font-size: 13px;
  color: var(--ink);
  font-weight: 500;
  transition: color 0.2s ease;
  font-family: inherit;
}

.skills-group-header:hover {
  color: var(--copper);
}

.skills-chevron {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--copper);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  display: inline-block;
}

.skills-group[data-open="true"] .skills-chevron {
  transform: rotate(180deg);
}

.skills-group-body {
  display: grid;
  grid-template-rows: 0fr;
  transition: grid-template-rows 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.skills-group[data-open="true"] .skills-group-body {
  grid-template-rows: 1fr;
}

.skills-group-inner {
  overflow: hidden;
}
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('.skills-group-header').forEach(header => {
      header.addEventListener('click', () => {
        const group = header.closest('.skills-group');
        const isOpen = group.getAttribute('data-open') === 'true';
        group.setAttribute('data-open', isOpen ? 'false' : 'true');
      });
    });
  });
</script>